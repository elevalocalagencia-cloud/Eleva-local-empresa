# Copiar para .env somente na VPS ou em ambiente controlado.
# Nao versionar segredos reais.

N8N_DOMAIN=n8m.elevalocal.shop
N8N_PROTOCOL=https
N8N_EDITOR_BASE_URL=https://n8m.elevalocal.shop
WEBHOOK_URL=https://n8m.elevalocal.shop
N8N_HOST=n8m.elevalocal.shop
N8N_PORT=5678
N8N_SECURE_COOKIE=true
N8N_PROXY_HOPS=1
N8N_ENCRYPTION_KEY=change-me
N8N_USER_MANAGEMENT_JWT_SECRET=change-me

DB_POSTGRESDB_HOST=postgresql
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=change-me
DB_POSTGRESDB_PASSWORD=change-me

QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PORT=6379

POSTGRES_DB=n8n
POSTGRES_USER=change-me
POSTGRES_PASSWORD=change-me

TRAEFIK_NETWORK=coolify
N8N_IMAGE=docker.n8n.io/n8nio/n8n:latest
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
