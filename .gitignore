# Local encrypted vault keys. Keep encrypted inventories tracked if ever added,
# but never commit private age keys.
*.env
!*.env.example
!backup-elevalocal.env.example
*.key
*.sql
*.tar.gz
*.tgz
__pycache__/
.pytest_cache/
tenants/secrets/.vault/*.key
!tenants/secrets/.vault/*.enc
tenants/runtime/*/.env
ops/backup-elevalocal.env
node_modules/
.next/
*.tsbuildinfo
.agents/
GEMINI.md
dev-server*.log
start-server*.log
lighthouse-portal.report.html
lighthouse-portal.report.json
legal/signed/*.pdf
legal/signed/*.docx
legal/signed/*/
!legal/signed/README.md
!legal/signed/.gitkeep
.DS_Store
