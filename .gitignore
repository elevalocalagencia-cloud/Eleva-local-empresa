.pytest_cache/
tenants/secrets/.vault/*.key
!tenants/secrets/.vault/*.enc
tenants/runtime/*/.env
ops/backup-elevalocal.env
node_modules/
.next/
*.tsbuildinfo
.agents/
GEMINI.md
dev-server*.log
start-server*.log
.DS_Store
