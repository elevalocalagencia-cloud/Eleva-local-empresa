BACKUP_ROOT=/root/eleva-backups
RETENTION_DAYS=7
BACKUP_MODE=local_only
OFFSITE_ENABLED=false
OFFSITE_TARGET=user@backup-host:/srv/elevalocal-backups

# restic offsite
RESTIC_REPOSITORY=b2:elevalocal-backups-prod:/prod
RESTIC_PASSWORD_FILE=/run/elevalocal/restic-repository-password
HEALTHCHECK_URL_SUCCESS=https://hc-ping.com/uuid-success
HEALTHCHECK_URL_FAIL=https://hc-ping.com/uuid-fail
B2_ACCOUNT_ID=
B2_ACCOUNT_KEY=

# opcional para Cloudflare R2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto

# monitoramento e operacao
OFFSITE_BUCKET_QUOTA_GB=
BACKUP_LOG_FILE=/var/log/elevalocal-backup.log
